<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7F5"
    android:fillViewport="true"
    tools:context=".AddUserActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header Layout using the background -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_rect_header"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="40dp"
            android:paddingEnd="24dp"
            android:paddingBottom="36dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:id="@+id/btnBack"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackgroundBorderless"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="2dp"
                    android:stateListAnimator="@animator/button_press_scale">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:contentDescription="Go Back"
                        android:src="@drawable/ic_back_arrow"
                        app:tint="#1B3A2B" />
                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="User Management"
                    android:textColor="#1B3A2B"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.03" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvAddUserTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:letterSpacing="-0.02"
                android:text="Register New User"
                android:textColor="#1B3A2B"
                android:textSize="28sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create a new client profile and initialize balance"
                android:textColor="#5A6B5E"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="24dp"
            android:paddingEnd="20dp"
            android:paddingBottom="32dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Full Name Field -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Full Name"
                        android:textColor="#2E7D32"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/etFullName"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="Enter full name"
                        android:inputType="textPersonName"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:textSize="16sp"
                        android:textColor="#2D3A30"
                        android:textColorHint="#7A8B7F"
                        android:backgroundTint="#2E7D32"
                        android:layout_marginBottom="20dp" />

                    <!-- Mobile Number Field -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mobile Number"
                        android:textColor="#2E7D32"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/etMobileNumber"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="Enter 10-digit number"
                        android:inputType="phone"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:textSize="16sp"
                        android:textColor="#2D3A30"
                        android:textColorHint="#7A8B7F"
                        android:backgroundTint="#2E7D32"
                        android:layout_marginBottom="20dp" />
                    <!-- Email Address -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email Address"
                        android:textColor="#2E7D32"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="Enter email address"
                        android:inputType="textEmailAddress"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:textSize="16sp"
                        android:textColor="#2D3A30"
                        android:textColorHint="#7A8B7F"
                        android:backgroundTint="#2E7D32"
                        android:layout_marginBottom="20dp" />

                    <!-- Password Field -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Password"
                        android:textColor="#2E7D32"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/etUserPassword"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="Create default password"
                        android:inputType="textPassword"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:textSize="16sp"
                        android:textColor="#2D3A30"
                        android:textColorHint="#7A8B7F"
                        android:backgroundTint="#2E7D32"
                        android:layout_marginBottom="8dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Corrected Button with clean white text visibility -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddUser"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:backgroundTint="@color/btn_state_color_selector"
                android:text="Add User"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:iconGravity="textStart"
                app:elevation="3dp"
                app:pressedTranslationZ="6dp"
                app:cornerRadius="14dp"
                app:rippleColor="#40A5D6A7"
                android:stateListAnimator="@animator/button_press_scale" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>