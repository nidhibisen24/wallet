<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F8E9"
    android:orientation="vertical"
    tools:context=".AllUsersActivity">

    <!--     LIGHT GREEN MINT HEADER (Top Wave)  -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#DCEDC8"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="32dp"
        android:paddingEnd="24dp"
        android:paddingBottom="28dp">

        <!-- Back Button & Subtitle Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <androidx.cardview.widget.CardView
                android:id="@+id/btnBackFromUsers"
                android:layout_width="32dp"
                android:layout_height="32dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:contentDescription="Go Back"
                    android:src="@android:drawable/ic_menu_revert"
                    app:tint="#2E7D32" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Fund Manager Database"
                android:textColor="#558B2F"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.02" />
        </LinearLayout>

        <!-- Main Title (Matching Create Account style) -->
        <TextView
            android:id="@+id/tvAllUsersTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All Registered Users"
            android:textColor="#1B5E20"
            android:textSize="26sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02" />
    </LinearLayout>

    <!--   FLOATING CARD FOR SEARCH & LIST       -->

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="16dp"
        android:layout_marginTop="-16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="20dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Search Field Box with Border Line -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="12dp"
                android:background="@android:drawable/edit_text"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="#78909C" />

                <EditText
                    android:id="@+id/etSearchUsers"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="10dp"
                    android:background="@null"
                    android:hint="Search user by name or phone..."
                    android:textColorHint="#90A4AE"
                    android:textColor="#37474F"
                    android:textSize="14sp"
                    android:inputType="text"
                    android:maxLines="1" />
            </LinearLayout>

            <!-- Users RecyclerView List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvUsers"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbars="vertical"
                tools:listitem="@layout/item_user" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>