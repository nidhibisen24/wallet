<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7F5"
    tools:context=".ui.QrManagementActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Top Header using your flat theme gradient color -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rect_header"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="48dp"
                android:paddingEnd="24dp"
                android:paddingBottom="48dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnBack"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginEnd="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackgroundBorderless"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="2dp"
                        android:stateListAnimator="@animator/button_press_scale">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:contentDescription="Go Back"
                            android:src="@drawable/ic_back_arrow"
                            app:tint="#1B3A2B"
                            tools:ignore="HardcodedText" />
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="QR Code Setup"
                        android:textColor="#1B3A2B"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:letterSpacing="-0.02"
                        tools:ignore="HardcodedText" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Manage your gateway QR code for client deposits"
                    android:textColor="#5A6B5E"
                    android:textSize="14sp"
                    tools:ignore="HardcodedText" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingBottom="32dp">

                <!-- Original 22dp CornerRadius & 6dp Elevation untouched -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="6dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:padding="24dp"
                        android:layout_marginTop="8dp">

                        <!-- Original 16dp CornerRadius untouched -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="250dp"
                            android:layout_height="250dp"
                            android:layout_marginTop="20dp"
                            android:layout_marginBottom="28dp"
                            app:cardBackgroundColor="#F4F7F5"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:strokeColor="#E2E8E4"
                            app:strokeWidth="1dp">

                            <ImageView
                                android:id="@+id/ivQrPreview"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_gravity="center"
                                android:layout_margin="12dp"
                                android:scaleType="fitCenter"
                                android:contentDescription="QR Code Preview"
                                tools:src="@android:drawable/ic_menu_report_image"
                                tools:ignore="HardcodedText" />
                        </androidx.cardview.widget.CardView>

                        <!-- Secondary Button mapped to soft mint background -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSelectQr"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginBottom="12dp"
                            android:backgroundTint="#EEFBEA"
                            android:text="Select QR Code"
                            android:textColor="#2E7D32"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            app:cornerRadius="12dp"
                            app:elevation="0dp"
                            app:pressedTranslationZ="2dp"
                            app:rippleColor="#202E7D32"
                            android:stateListAnimator="@animator/button_press_scale"
                            tools:ignore="HardcodedText" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnUploadQr"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:backgroundTint="@color/btn_state_color_selector"
                            android:text="Upload QR Code"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            app:cornerRadius="12dp"
                            app:elevation="3dp"
                            app:pressedTranslationZ="6dp"
                            app:rippleColor="#40A5D6A7"
                            android:stateListAnimator="@animator/button_press_scale"
                            tools:ignore="HardcodedText" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>