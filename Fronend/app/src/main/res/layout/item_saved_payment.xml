<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:id="@+id/cardAccount"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:layout_marginStart="16dp"
    android:layout_marginTop="4dp"
    android:layout_marginEnd="16dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="18dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="#E2E8E4"> <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvAccountName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Personal UPI"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#1B3A2B"/> <TextView
        android:id="@+id/tvDefault"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DEFAULT"
        android:textStyle="bold"
        android:textSize="11sp"
        android:textColor="#2E7D32"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:background="@drawable/bg_status_approved"
        tools:ignore="HardcodedText" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvUpi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="abc@paytm"
        android:textSize="14sp"
        android:textColor="#5A6B5E"
        android:layout_marginTop="4dp"
        android:fontFamily="sans-serif"/>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="116dp"
        android:layout_height="116dp"
        android:layout_marginTop="16dp"
        app:cardElevation="0dp"
        app:cardCornerRadius="12dp"
        app:strokeWidth="1dp"
        app:strokeColor="#E2E8E4"
        app:cardBackgroundColor="#F4F7F5"> <ImageView
        android:id="@+id/imgQr"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="8dp"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_report_image"
        android:contentDescription="UPI QR Code" />
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEdit"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="46dp"
            android:text="Edit"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:textColor="#5A6B5E"
            android:layout_marginEnd="8dp"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"
            app:strokeColor="#E2E8E4"
            app:cornerRadius="19dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDelete"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="46dp"
            android:text="Delete"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:textColor="#E53935"
            android:layout_marginEnd="8dp"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"
            app:strokeColor="#FFCDD2"
            app:cornerRadius="19dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDefault"
            android:layout_width="wrap_content"
            android:layout_height="46dp"
            android:text="Default"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"
            app:cornerRadius="19dp"
            android:backgroundTint="#2E7D32"/>

    </LinearLayout>

</LinearLayout>

</com.google.android.material.card.MaterialCardView>